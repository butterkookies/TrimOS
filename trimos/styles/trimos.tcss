/* TrimOS — Claude Code-inspired dark theme */
/* Clean, minimal, terminal-hacker aesthetic */

Screen {
    background: #0c0c0c;
    color: #d4d4d4;
}

/* ─── Top Header Bar ─── */
#header-bar {
    dock: top;
    height: 1;
    background: #1a1a2e;
    color: #888888;
    padding: 0 1;
    layout: horizontal;
}

#header-left {
    width: 1fr;
    height: 1;
    content-align: left middle;
}

#header-right {
    width: auto;
    height: 1;
    content-align: right middle;
}

/* ─── Top Section: Mascot + Perf Graphs side by side ─── */
#top-section {
    height: 8;
    layout: horizontal;
    margin: 0 1;
}

#mascot-panel {
    width: 18;
    height: 8;
    background: #111118;
    border: round #2a2a3a;
    content-align: center middle;
    margin-right: 1;
}

Mascot {
    width: 100%;
    height: 100%;
    content-align: center middle;
    background: transparent;
}

#perf-panel {
    width: 1fr;
    height: 8;
    background: #111118;
    border: round #2a2a3a;
    border-title-color: #00d4ff;
    border-title-style: bold;
    padding: 1 0;
}

/* ─── Table Section ─── */
#table-section {
    height: 1fr;
    margin: 0 1;
    layout: vertical;
}

#table-info-bar {
    height: 1;
    layout: horizontal;
    padding: 0 1;
    margin-top: 0;
    background: #111118;
}

#table-title {
    width: 1fr;
    height: 1;
    content-align: left middle;
    color: #00d4ff;
    text-style: bold;
}

#filter-label {
    width: auto;
    height: 1;
    content-align: right middle;
    color: #555555;
}

#trimmable-label {
    width: auto;
    height: 1;
    content-align: right middle;
    color: #ff4466;
    margin-left: 2;
}

ServiceTable {
    height: 1fr;
    background: #111118;
    border: round #2a2a3a;
    border-title-color: #00d4ff;
    border-title-style: bold;
    scrollbar-size-vertical: 1;
    scrollbar-color: #2a2a3a;
    scrollbar-color-hover: #00d4ff;
    scrollbar-color-active: #00d4ff;
}

ServiceTable > .datatable--header {
    background: #1a1a2e;
    color: #00d4ff;
    text-style: bold;
}

ServiceTable > .datatable--cursor {
    background: #1a2a3a;
    color: #ffffff;
}

ServiceTable > .datatable--even-row {
    background: #111118;
}

ServiceTable > .datatable--odd-row {
    background: #0e0e14;
}

/* ─── Detail Panel ─── */
#detail-panel {
    height: auto;
    min-height: 6;
    max-height: 10;
    margin: 0 1;
    background: #0d0d14;
    border: round #2a2a3a;
    border-title-color: #00d4ff;
    padding: 0 0;
}

/* ─── Footer ─── */
Footer {
    background: #1a1a2e;
    color: #888888;
}

Footer > .footer--key {
    background: #2a2a3a;
    color: #00d4ff;
    text-style: bold;
}

Footer > .footer--description {
    color: #888888;
}

/* ─── Notifications ─── */
Toast {
    background: #1a1a2e;
    border: round #00d4ff;
    color: #e0e0e0;
}
